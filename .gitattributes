# Plang uses Python-like syntax; tell GitHub Linguist to treat .p/.ph as
# Python so the repo gets sensible highlighting and language stats (there is
# no first-class "Plang" in Linguist).
*.p   linguist-language=Python
*.ph  linguist-language=Python

# The C under bootstrap/ is generated by the compiler (the build seed): keep it
# out of language stats and collapsed in diffs.
bootstrap/**  linguist-generated=true
