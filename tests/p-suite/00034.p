def main() -> int:
    x: int

    x = 0
    while True:
        break
    while True:
        if x == 5:
            break
        x = x + 1
        continue
    while True:
        if x == 10:
            break
        x = x + 1
        continue
    do:
        if x == 15:
            break
        x = x + 1
        continue
    while True
    return x - 15
